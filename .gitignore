# ── .gitignore ──
# Comprehensive ignore file for URL Shortener project

# ═══════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
.hypothesis/

# ═══════════════════════════════════════════════════════
# Virtual Environments
# ═══════════════════════════════════════════════════════
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ═══════════════════════════════════════════════════════
# Database Files (DO NOT COMMIT LOCAL DATA)
# ═══════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
*.db-journal

# PostgreSQL
*.dump
*.sql

# ═══════════════════════════════════════════════════════
# Environment Variables (SECURITY: Never commit secrets!)
# ═══════════════════════════════════════════════════════
.env
.env.local
.env.*.local
*.env

# ═══════════════════════════════════════════════════════
# IDE / Editors
# ═══════════════════════════════════════════════════════

# VSCode
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ═══════════════════════════════════════════════════════
# Operating System Files
# ═══════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ═══════════════════════════════════════════════════════
# Logs & Temporary Files
# ═══════════════════════════════════════════════════════
*.log
logs/
*.tmp
*.temp
*.bak
*.swp

# ═══════════════════════════════════════════════════════
# Docker & Containerization
# ═══════════════════════════════════════════════════════
docker-compose.override.yml

# ═══════════════════════════════════════════════════════
# Application Specific
# ═══════════════════════════════════════════════════════

# Alembic (database migrations - keep versions/ but ignore generated files)
alembic.ini.bak

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebook (if used for analysis)
.ipynb_checkpoints

# ═══════════════════════════════════════════════════════
# Project Specific - Files NOT to commit
# ═══════════════════════════════════════════════════════

# Local development database
urlshortener.db

# Debug/test scripts (uncomment if you want to ignore)
# debug_*.py
# test_*.py (but we want to keep tests/ folder!)
check_schema.py
installed_packages.txt

# Local configuration overrides
config.local.py

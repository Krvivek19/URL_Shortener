# ── .env.example ──
# Copy this file to .env and modify as needed
# Local development environment variables.

# Application Settings
APP_NAME=URL Shortener
BASE_URL=http://localhost:8000

# Database Configuration
# For local development with SQLite (no setup required):
DATABASE_URL=sqlite:///./urlshortener.db

# For PostgreSQL (requires PostgreSQL installed):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urlshortener

# For Docker PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/urlshortener

# Redis Configuration (optional - app works without it)
REDIS_URL=redis://localhost:6379/0

# Cache Settings
CACHE_TTL=3600

# Rate Limiting (requests per minute per IP)
RATE_LIMIT=10/minute

# Short Code Length
SHORT_CODE_LENGTH=6
